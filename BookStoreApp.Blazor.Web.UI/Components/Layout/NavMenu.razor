<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">BookStoreApp.Blazor.Web.UI</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></i> Home
            </NavLink>
        </div>
        <AuthorizeView>
            @*cip...41*@
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link">
                        <i class="bi bi-person-fill"></i> @context.User?.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="users/logout">
                        <i class="bi bi-box-arrow-left"></i> Logout
                    </NavLink>
                </div>
                <hr />
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="authors/">
                        <i class="bi bi-people-fill"></i> Authors
                    </NavLink>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="users/register">
                        <i class="bi bi-person-plus-fill"></i> Register
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="users/login">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

