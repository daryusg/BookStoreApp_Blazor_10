@page "/authors/update/{id:int}" //cip...47
@inject IAuthorService authorService
@inject NavigationManager navManager
@using AutoMapper
@inject IMapper _mapper
@attribute [Authorize(Roles = Roles.Administrator)] //cip...50

@if (!string.IsNullOrWhiteSpace(errorMessage)) //cip...20260611 chatgpt: added to display error message if book creation fails.
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

<h3>Edit Author</h3>
<br />
<EditForm Model="Author" OnValidSubmit="HandleUpdateAuthorAsync" FormName="UpdateAuthor">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-group">
        <label for="firstName">Firstname</label>
        <InputText id="firstName" @bind-Value="Author.FirstName" class="form-control" />
        <ValidationMessage For="@(() => Author.FirstName)" />
    </div>
    <br />
    <div class="form-group">
        <label for="lastName">Lastname</label>
        <InputText id="lastName" @bind-Value="Author.LastName" class="form-control" />
        <ValidationMessage For="@(() => Author.LastName)" />
    </div>
    <br />
    <div class="form-group">
        <label for="bio">Bio</label>
        <InputText id="bio" @bind-Value="Author.Bio" class="form-control" />
        <ValidationMessage For="@(() => Author.Bio)" />
    </div>
    <br />
    <button type="submit" class="btn btn-primary">
        <span class="bi bi-pencil-fill"></span>
        Update Author
    </button>
    <button @onclick="NavigateToAuthors" class="btn btn-secondary type="button">
        <span class="bi bi-rewind-fill"></span>
        Back to list
    </button>
</EditForm>

@code {
    [Parameter]
    public int id { get; set; } //automatically binds to the route parameter

    private AuthorUpdateDto Author { get; set; } = new();

    private string errorMessage = string.Empty; //cip...20260611 chatgpt: added to display error message if book creation fails.

    //when the component loads, get the author details and populate the form
    override protected async Task OnInitializedAsync()
    {
        var response = await authorService.GetAsync(id);
        if (response.Success)
            Author = _mapper.Map<AuthorUpdateDto>(response.Data); //map from AuthorReadOnlyDto to AuthorUpdateDto
    }

    private async Task HandleUpdateAuthorAsync()
    {
        errorMessage = string.Empty; //clear error message before attempting update

        var response = await authorService.UpdateAsync(id, Author);
        if (response.Success)
            NavigateToAuthors();
        else
            //errorMessage = response.Message;
            errorMessage = response.Message + (response.ValidationErrors != null ? $"\nValidation Errors: {response.ValidationErrors}" : string.Empty); //20260611
    }

    private void NavigateToAuthors()
    {
        navManager.NavigateTo("/authors/");
    }
}
