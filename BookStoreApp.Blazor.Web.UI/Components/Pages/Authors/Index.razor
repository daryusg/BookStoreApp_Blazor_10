@page "/authors/" //cip...44
@inject IAuthorService authorService //cip...45
@inject IJSRuntime jsRuntime //cip...49

<h3>Index</h3>
@if (!response.Success)
{
    <div class="alert alert-danger">
        <h4>@response.Message</h4>
    </div>
}
else //cip...46 refactored
{
    @if (authors == null)
    {
        <div class="alert alert-info">
            <h4>Loading data...</h4>
        </div>
    }
    else
    {
        <a class="btn btn-dark" href="/authors/create"><span class="bi bi-plus" aria-hidden="true"></span>Create</a>
        <br />
        <table class="table table-responsive">
            <thead>
                <tr>
                    <th>Firstname</th>
                    <th>Lastname</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var author in authors)
                {
                    <tr>
                        <td>@author.FirstName</td>
                        <td>@author.LastName</td>
                        <td>
                            <a class="btn btn-primary" href="/authors/details/@author.Id"><span class="bi bi-book" aria-hidden="true"></span>View</a>
                            <a class="btn btn-warning" href="/authors/update/@author.Id"><span class="bi bi-pencil" aria-hidden="true"></span>Edit</a>
                            <button class="btn btn-danger" @onclick=@(() => Delete(@author.Id))><span class="bi bi-trash" aria-hidden="true"></span>Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<AuthorReadOnlyDto> authors;
    private Response<List<AuthorReadOnlyDto>> response = new() { Success = true };

    protected override async Task OnInitializedAsync() //cip...44,45
    {
        response = await authorService.GetAsync();
        if (response.Success)
        {
            authors = response.Data;
        }
    }

    private async Task Delete(int authorId) //cip...49
    {
        var author = authors.First(a => a.Id == authorId);
        var confirm = await jsRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete the author ({author.FirstName} {author.LastName})?");
        if (confirm)
        {
            var response = await authorService.DeleteAsync(authorId);
            if (response.Success)
                await OnInitializedAsync(); //refresh the list after deletion
        }
    }
}
