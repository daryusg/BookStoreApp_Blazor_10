@inject IAuthorService authorService //cip...66 chatgpt rewrite
@inject IJSRuntime jsRuntime
@inject ILogger<AuthorsTable> logger

<table class="table table-responsive">
    <thead>
        <tr>
            <th>Firstname</th>
            <th>Lastname</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        <!-- <Virtualize TItem="AuthorReadOnlyDto" ItemsProvider="LoadAuthors" Context="author" @ref="virtualizeComponent"> -->
        <!-- 20260608 chatgpt potential fix for azure only showing 106 items in azure -->
        <Virtualize TItem="AuthorReadOnlyDto" ItemsProvider="LoadAuthors" Context="author" ItemSize="50" @ref="virtualizeComponent">
            <tr>
                <td>@author.FirstName</td>
                <td>@author.LastName</td>
                <td>
                    <a class="btn btn-primary" href="/authors/details/@author.Id"><span class="bi bi-book" aria-hidden="true"></span> Details</a>

                    <AuthorizeView Roles="@Roles.Administrator">
                        <a class="btn btn-warning" href="/authors/update/@author.Id"><span class="bi bi-pencil" aria-hidden="true"></span> Edit</a>
                        <button class="btn btn-danger" @onclick="() => DeleteAsync(author)"><span class="bi bi-trash" aria-hidden="true"></span> Delete</button>
                    </AuthorizeView>
                </td>
            </tr>
        </Virtualize>
    </tbody>
</table>

@code {
    private Virtualize<AuthorReadOnlyDto>? virtualizeComponent; @*Reference to the Virtualize component. Used so we can call RefreshDataAsync() after deleting an author*@
    private List<AuthorReadOnlyDto> authors = []; @*Stores the currently loaded authors. Needed because Virtualize only provides the visible items. We use this list when looking up an author before deletion*@

    @*Called automatically by Virtualize whenever more data is needed.
        request.StartIndex: The first row Virtualize wants.
        request.Count: How many rows Virtualize wants*@
    private async ValueTask<ItemsProviderResult<AuthorReadOnlyDto>> LoadAuthors(ItemsProviderRequest request)
    {
        @*Call the API/service to retrieve a "page" of authors*@
        var response = await authorService.GetAsync(
            new QueryParameters
            {
                StartIndex = request.StartIndex,
                PageSize = request.Count
            });

        @*If the request failed, return an empty result set.
            Virtualize requires:
                - the collection of items
                - the total item count*@
        if (!response.Success || response.Data == null)
        {
            return new ItemsProviderResult<AuthorReadOnlyDto>([], 0);
        }

        @*Return:
            1. the loaded items
            2. the total number of records in the database
            Virtualize uses TotalCount to calculate scrollbar size.*@
        logger.LogInformation("Fetched {Count} authors out of {Total}", response.Data.Items.Count, response.Data.TotalCount);
        return new ItemsProviderResult<AuthorReadOnlyDto>(response.Data.Items, response.Data.TotalCount);
    }

    private async Task DeleteAsync(AuthorReadOnlyDto author)
    {
        var confirm = await jsRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete this author: {author.FirstName} {author.LastName}?");

        if (!confirm)
            return;

        var response = await authorService.DeleteAsync(author.Id);
        if (response.Success && virtualizeComponent != null)
        {
            await virtualizeComponent.RefreshDataAsync();
            StateHasChanged();
        }
    }
}